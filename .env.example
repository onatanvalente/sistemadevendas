# Ambiente
NODE_ENV=development
PORT=3000

# Banco de dados PostgreSQL
DATABASE_URL=postgresql://postgres:senha@localhost:5432/varlensys_db

# JWT (ALTERAR EM PRODUÇÃO — NÃO usar os defaults!)
JWT_SECRET=GERAR_UM_SECRET_FORTE_AQUI
JWT_EXPIRES_IN=2h

# JWT Master (admin SaaS - segredo DIFERENTE do tenant)
MASTER_JWT_SECRET=GERAR_OUTRO_SECRET_FORTE_AQUI

# CORS (lista de origens separadas por vírgula)
CORS_ORIGINS=https://seusite.com.br

# Segurança CSP
# Em produção, monitore os relatórios em /api/csp-report e depois remova
# handlers inline para migrar CSP ativa para script-src-attr 'none'.

# Railway vai injetar DATABASE_URL automaticamente
